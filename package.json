{
  "name": "peak-district-downhill",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:itch": "vite build --mode itch --outDir dist-itch",
    "package:itch": "npm run build:itch && node tools/itch/package.js",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "terrain:build": "node tools/terrain/buildTerrain.js && node tools/terrain/fetchRoute.js && node tools/terrain/fetchLandcover.js && node tools/terrain/fetchPaths.js && node tools/terrain/fetchBuildings.js && node tools/terrain/fetchWater.js",
    "terrain:trees": "node tools/terrain/buildTrees.js",
    "terrain:placeholder": "node tools/terrain/generatePlaceholder.js"
  },
  "dependencies": {
    "cannon-es": "0.20.0",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "geotiff": "^3.0.5",
    "jsdom": "^29.1.1",
    "proj4": "^2.15.0",
    "vite": "8.1.3",
    "vitest": "^4.1.9"
  }
}
